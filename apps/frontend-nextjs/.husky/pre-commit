#!/usr/bin/env sh
set -e

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
APP_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

run_yarn() {
if command -v corepack >/dev/null 2>&1; then
corepack yarn "$@"
else
yarn "$@"
fi
}

cd "$APP_DIR"

STAGED_FILES=$(git diff --cached --name-only)
export PRECOMMIT_STAGED_FILES="$STAGED_FILES"

run_yarn run lint-staged
run_yarn run pre-commit:deps-check
