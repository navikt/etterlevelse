{
  "name": "frontend-nextjs",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint-staged": "lint-staged",
    "test": "yarn lint-staged",
    "start": "next start",
    "prettier:check": "prettier -c ./app",
    "eslint:check": "eslint . --cache --max-warnings=0",
    "verify:deps-upgrade": "yarn run prettier:check && yarn run eslint:check && yarn run build",
    "pre-commit:deps-check": "node scripts/precommit-deps-check.mjs",
    "lint": "eslint . && prettier -c ./app",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"./app\"",
    "prepare": "cd ../../ && husky apps/frontend-nextjs/.husky",
    "prettier": "prettier --write \"./app\"",
    "type-check": "tsc --project tsconfig.json --noEmit --skipLibCheck false --incremental false",
    "postinstall": "patch-package && husky",
    "find-deadcode": "ts-prune | grep -v '(used in module)' | grep -E -v ' - default$'"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --list-different --write",
      "eslint --cache",
      "bash -c 'yarn run type-check'"
    ]
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@fontsource/source-sans-pro": "^5.2.5",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@navikt/aksel-icons": "^8.14.0",
    "@navikt/ds-css": "^8.14.0",
    "@navikt/ds-react": "^8.14.0",
    "@navikt/ds-tailwind": "^8.14.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-list": "^3.27.1",
    "@tiptap/extension-ordered-list": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "axios": "^1.18.1",
    "graphql": "17.0.1",
    "json-diff-kit": "^1.0.35",
    "lodash": "^4.18.1",
    "marked": "^18.0.5",
    "moment": "^2.30.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-is": "^19",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "react-markdown-editor-lite": "^1.4.2",
    "react-process-string": "^1.2.0",
    "recharts": "^3.9.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.2",
    "turndown": "^7.2.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "formik": "^2.4.9",
    "husky": "^9.1.7",
    "lint-staged": "17.0.8",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "react-select": "^5.10.2",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.16.0"
}
