{
  "name": "frontend-nextjs",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "yarn lint-staged",
    "start": "next start",
    "prettier:check": "prettier -c ./app",
    "eslint:check": "eslint . --cache --max-warnings=0",
    "verify:deps-upgrade": "yarn run prettier:check && yarn run eslint:check && yarn run build",
    "pre-commit:deps-check": "node scripts/precommit-deps-check.mjs",
    "lint": "eslint . && prettier -c ./app",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"./app\"",
    "prepare": "cd ../../ && husky apps/frontend-nextjs/.husky",
    "prettier": "prettier --write \"./app\"",
    "type-check": "tsc --project tsconfig.json --noEmit --skipLibCheck false --incremental false",
    "postinstall": "patch-package && husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --list-different --write",
      "eslint --cache",
      "bash -c 'yarn run type-check'"
    ]
  },
  "dependencies": {
    "@apollo/client": "^4.1.7",
    "@fontsource/source-sans-pro": "^5.2.5",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@navikt/aksel-icons": "^8.10.1",
    "@navikt/ds-css": "^8.10.1",
    "@navikt/ds-react": "^8.10.1",
    "@navikt/ds-tailwind": "^8.10.1",
    "@tailwindcss/postcss": "^4.2.3",
    "axios": "^1.15.1",
    "draft-js": "^0.11.7",
    "graphql": "^16.13.2",
    "json-diff-kit": "^1.0.35",
    "lodash": "^4.18.1",
    "markdown-draft-js": "^2.4.0",
    "moment": "^2.30.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-draft-wysiwyg-next": "^1.17.2",
    "react-helmet-async": "^3.0.0",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "react-markdown-editor-lite": "^1.4.2",
    "react-process-string": "^1.2.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.2.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/draft-js": "^0.11.20",
    "@types/lodash": "^4.17.24",
    "@types/markdown-draft-js": "^2.2.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "formik": "^2.4.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "react-select": "^5.10.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.14.1"
}
